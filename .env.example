# Riot developer API key — https://developer.riotgames.com
RIOT_API_KEY=RGAPI-your-key-here

# Comma-separated origins allowed to call the API (leave empty to allow all in dev)
CORS_ORIGIN=http://localhost:5173

# API server port
PORT=3001
# Vite client (baked in at build time — set these on Railway before deploy/rebuild)
VITE_PUBLIC_POSTHOG_KEY=phc_your_project_token
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
